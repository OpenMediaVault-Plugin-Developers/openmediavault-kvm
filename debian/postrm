#!/bin/sh

set -e

. /etc/default/openmediavault
. /usr/share/openmediavault/scripts/helper-functions

ipFwdConf="/etc/sysctl.conf.d/ip_forward.conf"

remove_action() {
    if [ -f "${ipFwdConf}" ]; then
        rm ${ipFwdConf}
    fi
    # Stop and disable the monitoring service
    systemctl stop omv-kvm-monitor 2>/dev/null || true
    systemctl disable omv-kvm-monitor 2>/dev/null || true
    rm -f /etc/systemd/system/omv-kvm-monitor.service
    rm -f /etc/nginx/openmediavault-webgui.d/kvm-monitor.conf
    systemctl daemon-reload 2>/dev/null || true
    # Reload nginx if running
    systemctl reload nginx 2>/dev/null || true
    # Activate trigger to purge cached files.
    dpkg-trigger update-workbench
}

case "$1" in
    purge)
        remove_action
        omv_config_delete "/config/services/kvm"
        rm -f /etc/omv-backup-vm.list /etc/cron.d/omv-backup-vm /var/log/omv-backup-vm.log*
    ;;

    remove)
        remove_action
    ;;

    upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
    ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
    ;;
esac

exit 0
